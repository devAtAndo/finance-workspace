{
  "name": "@ando/config",
  "version": "0.1.0",
  "private": true,
  "description": "Runtime configuration: zod-validated env, app registry, feature flags.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./apps": {
      "types": "./dist/apps.d.ts",
      "import": "./dist/apps.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.js"
    },
    "./flags": {
      "types": "./dist/flags.d.ts",
      "import": "./dist/flags.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ando/eslint-config": "workspace:*",
    "@ando/tsconfig": "workspace:*",
    "@types/node": "^20.16.10",
    "eslint": "^9.11.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
