{
  "name": "@ando/workspace",
  "version": "0.1.0",
  "private": true,
  "description": "workspace.andofoods.co — the Ando Finance launcher and admin surface.",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint src middleware.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .next .turbo dist .open-next",
    "cf:build": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion",
    "cf:preview": "opennextjs-cloudflare preview --dangerouslyUseUnsupportedNextVersion",
    "cf:deploy": "opennextjs-cloudflare deploy --dangerouslyUseUnsupportedNextVersion",
    "cf:dryrun": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion && wrangler deploy --dry-run"
  },
  "dependencies": {
    "@ando/auth": "workspace:*",
    "@ando/config": "workspace:*",
    "@ando/db": "workspace:*",
    "@ando/ui": "workspace:*",
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@ando/eslint-config": "workspace:*",
    "@ando/tsconfig": "workspace:*",
    "@opennextjs/cloudflare": "^1.0.0",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.11.0",
    "eslint-config-next": "14.2.15",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2",
    "wrangler": "^3.80.0"
  }
}
