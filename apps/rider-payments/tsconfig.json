{
  "extends": "@ando/tsconfig/nextjs.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "allowJs": true,
    "noUncheckedIndexedAccess": false,
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "proxy.ts",
    "test/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", ".next"]
}
