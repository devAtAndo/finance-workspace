    "bcryptjs": "^2.4.3",
    "next": "14.2.33",
    "next-auth": "^4.24.11",
    "nodemailer": "^7.0.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tesseract.js": "^5.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ando/eslint-config": "workspace:*",
    "@ando/tsconfig": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.10",
    "@types/nodemailer": "^7.0.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
