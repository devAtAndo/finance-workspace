# Copy to .env.local and fill in. Never commit real secrets.
# All vars consumed through @ando/config — adding one means updating its zod schema.

NODE_ENV=development

# Cloudflare Access — team domain (no scheme, no trailing slash)
CF_ACCESS_TEAM_DOMAIN=ando.cloudflareaccess.com

# Per-app AUD tags from `terraform output access_audiences`
CF_ACCESS_AUD_WORKSPACE=replace-me
CF_ACCESS_AUD_PETTY_CASH=replace-me
CF_ACCESS_AUD_RIDER_PAYMENTS=replace-me

# Shared iam Postgres
IAM_DATABASE_URL=postgres://postgres:postgres@localhost:5432/iam

# Feature flags (default false in prod; WORKSPACE_ENABLED defaults true in dev)
WORKSPACE_ENABLED=true
PETTY_CASH_AUTH_V2=false
RIDER_CF_ACCESS=false
